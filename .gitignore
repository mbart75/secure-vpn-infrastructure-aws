# ── Terraform ─────────────────────────────────────────────────────────────────
.terraform/
.terraform.tfstate.lock.info

# State can contain resource metadata and is machine-specific. Never commit it.
terraform.tfstate
terraform.tfstate.backup
terraform.tfstate.d/

# Variable files may hold IP addresses and other environment detail.
# terraform.tfvars.example is intentionally tracked.
*.tfvars
*.tfvars.json

# Saved plan artifacts.
tfplan-*.bin
*.tfplan

crash.log
crash.*.log

override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ── Keys and VPN material — never commit ──────────────────────────────────────
# .terraform.lock.hcl is intentionally tracked: it pins provider checksums.
*.pem
*.key
*.conf
*-qrcode.txt
wireguard-clients/

# SSH private keys carry no extension, so the patterns above would miss a key
# copied into the project directory.
id_rsa
id_dsa
id_ecdsa
id_ed25519
id_*_key
*_rsa
*_ed25519

# ── Notes de session locales — jamais publiées ────────────────────────────────
Transmission.md
transmissions/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
