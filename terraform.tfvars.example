# ==============================================================================
# terraform.tfvars.example — copy to terraform.tfvars and edit as needed
#
#   cp terraform.tfvars.example terraform.tfvars
#   terraform apply
#
# terraform.tfvars is gitignored and never committed.
# Every value below is optional: the defaults in variables.tf work as they are.
# ==============================================================================

# --- Region -------------------------------------------------------------------
# Pick one close to you; latency through the tunnel follows this choice.
# aws_region = "eu-west-3"      # Paris
# aws_region = "eu-central-1"   # Frankfurt
# aws_region = "us-east-1"      # N. Virginia

# --- Naming -------------------------------------------------------------------
# Prefix applied to every AWS resource this stack creates.
# project_name = "wireguard-vpn"

# --- Devices ------------------------------------------------------------------
# One .conf file and one QR code is generated per entry, each with its own
# key pair, preshared key and VPN address. Add or remove entries freely.
# Names: letters, digits, hyphens and underscores, up to 32 characters.
# wireguard_clients = ["phone", "laptop"]
# wireguard_clients = ["phone", "laptop", "tablet", "work-laptop", "partner-phone"]

# --- Access -------------------------------------------------------------------
# CIDR allowed to reach SSH. Leave unset to auto-detect the public IP of the
# machine running Terraform and pin it as a /32.
#
# Set it explicitly when Terraform runs offline or from CI, or when you want the
# security group to stay stable as your own IP changes.
# allowed_ssh_cidr = "203.0.113.4/32"

# SSH port. The server updates both sshd and its systemd socket unit to match.
# ssh_port = 2222

# UDP port WireGuard listens on.
# 51820 is the standard port and works on most networks, including home ISPs.
# Hotel, corporate and campus Wi-Fi sometimes filter it. UDP 443 carries QUIC
# and HTTP/3, so it is almost never blocked and blends into normal web traffic.
# Set this before you travel rather than discovering the block on arrival.
# wireguard_port = 51820
# wireguard_port = 443

# Public key installed on the server. Must be a .pub file, never a private key.
# ssh_public_key_path = "~/.ssh/id_ed25519.pub"

# --- Networking ---------------------------------------------------------------
# Private range used inside the tunnel; the server takes the first address.
# A /24 holds 253 clients.
# vpn_network_cidr = "10.8.0.0/24"

# CIDR of the dedicated VPC created for the server.
# vpc_cidr = "10.20.0.0/24"

# Resolvers pushed to clients. Defaults to Cloudflare.
# client_dns_servers = ["1.1.1.1", "1.0.0.1"]
# client_dns_servers = ["9.9.9.9", "149.112.112.112"]   # Quad9

# --- Compute ------------------------------------------------------------------
# instance_type = "t3.micro"

# Pin the AMI for reproducible rebuilds. Unset resolves the current Ubuntu
# 24.04 LTS image from Canonical's public SSM parameter.
# ami_id = "ami-0123456789abcdef0"
